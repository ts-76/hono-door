{
  "name": "hono-door-ui",
  "version": "0.1.0",
  "description": "Optional browser admin UI for hono-door short-lived public links and QR code issuing.",
  "license": "MIT",
  "author": "ts-76",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ts-76/hono-door.git",
    "directory": "packages/hono-door-ui"
  },
  "homepage": "https://github.com/ts-76/hono-door#readme",
  "bugs": {
    "url": "https://github.com/ts-76/hono-door/issues"
  },
  "keywords": [
    "hono",
    "cloudflare-workers",
    "durable-objects",
    "short-link",
    "admin-ui",
    "qr-code"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build:ui-client && bun scripts/build-package.ts && tsc -p tsconfig.build.json && bun scripts/fix-generated-types.ts",
    "build:ui-client": "bun scripts/build-ui-client.ts",
    "check:ui-client": "bun scripts/build-ui-client.ts --check",
    "prepack": "bun run check:ui-client && bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "hono": "^4.10.7",
    "hono-door": "workspace:^",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "esbuild": "0.28.1"
  }
}
